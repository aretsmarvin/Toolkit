{
  "branding": {
    "app_name": "Toolkit",
    "window_title": "Toolkit - Digital Forensics Toolkit",
    "logo_path": null,
    "icon_path": null
  },
  "logging": {
    "log_dir": "~/.toolkit/logs"
  },
  "external_tools": [
    {
      "name": "Autopsy",
      "description": "Open source digital forensics platform for analysing disk images, file systems and more.",
      "category": "Workstations",
      "command": ["open", "-a", "Autopsy"],
      "install": {
        "strategy": "homebrew_cask",
        "cask": "autopsy"
      },
      "update": {
        "type": "command",
        "command": ["brew", "upgrade", "--cask", "autopsy"]
      }
    }
  ]
}
